<?xml version="1.0" encoding="utf-8"?>
<!--
    item_message.xml
    Changes vs original:
      1. Added sentSongCard / receivedSongCard FrameLayout slots so the adapter
         can inflate item_message_song.xml into them for type=="song".
      2. Reaction badge now shows grouped emoji + count ("❤️ 3") via a
         horizontal LinearLayout instead of a single TextView.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- ══════════════ SENT (right side) ══════════════ -->
    <LinearLayout
        android:id="@+id/sentContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:maxWidth="280dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/sentBubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="80dp"
            android:orientation="vertical"
            android:background="@drawable/bg_bubble_sent">

            <!-- Reply quote preview -->
            <LinearLayout
                android:id="@+id/sentReplyQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_quote_strip_sent"
                android:layout_margin="6dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSentReplySender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFE3D6"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvSentReplyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFE3D6"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Song card slot (type == "song") -->
            <FrameLayout
                android:id="@+id/sentSongCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Media: photo or video -->
            <FrameLayout
                android:id="@+id/sentMediaFrame"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_margin="4dp"
                android:visibility="gone">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivSentMedia"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/RoundedImageCorners" />

                <ImageView
                    android:id="@+id/ivSentPlayIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_circle"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- Plain text -->
            <TextView
                android:id="@+id/tvSent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="2dp" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tvSentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:paddingStart="14dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="6dp"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Grouped reaction badge (emoji + count) -->
        <LinearLayout
            android:id="@+id/sentReactionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="-10dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_reaction_badge"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvSentReactionEmojis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSentReactionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════ RECEIVED (left side) ══════════════ -->
    <LinearLayout
        android:id="@+id/receivedContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:maxWidth="280dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/receivedBubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="80dp"
            android:orientation="vertical"
            android:background="@drawable/bg_bubble_received">

            <!-- Reply quote preview -->
            <LinearLayout
                android:id="@+id/receivedReplyQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_quote_strip_received"
                android:layout_margin="6dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvReceivedReplySender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FF9D7A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvReceivedReplyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Song card slot (type == "song") -->
            <FrameLayout
                android:id="@+id/receivedSongCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Media -->
            <FrameLayout
                android:id="@+id/receivedMediaFrame"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_margin="4dp"
                android:visibility="gone">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivReceivedMedia"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/RoundedImageCorners" />

                <ImageView
                    android:id="@+id/ivReceivedPlayIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_circle"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- Plain text -->
            <TextView
                android:id="@+id/tvReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="2dp" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tvReceivedTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:paddingStart="14dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="6dp"
                android:textColor="#99FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Grouped reaction badge -->
        <LinearLayout
            android:id="@+id/receivedReactionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginTop="-10dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_reaction_badge"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvReceivedReactionEmojis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvReceivedReactionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>