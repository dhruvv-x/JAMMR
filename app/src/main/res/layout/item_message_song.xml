<?xml version="1.0" encoding="utf-8"?>
<!--
    item_message_song.xml
    Inflated by MessageAdapter as a child inside sentBubble / receivedBubble
    when message.type == "song". Replaces the plain tvSent/tvReceived text view.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/songCard"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Artwork + play button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="160dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivSongArtwork"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedImageCorners" />

        <!-- Dark scrim so play button is visible on any artwork -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#55000000"
            app:shapeAppearanceOverlay="@style/RoundedImageCorners" />

        <ImageView
            android:id="@+id/ivSongPlayBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play_circle"
            android:alpha="0.92" />

    </FrameLayout>

    <!-- Track info -->
    <TextView
        android:id="@+id/tvSongTrackName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tvSongArtistName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Thin accent divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#33FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="🎵 Tap to preview"
        android:textColor="#AAFFFFFF"
        android:textSize="11sp" />

</LinearLayout>